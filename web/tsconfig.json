{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node10",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@reearth-cms/e2e/*": ["./e2e/*"],
      "@reearth-cms/*": ["./src/*"]
    },
    "types": ["@testing-library/jest-dom"],
    "maxNodeModuleJsDepth": 10,
    "allowImportingTsExtensions": true,
    "strictNullChecks": true,
    // esModuleInterop=false and moduleResolution=node10 are deprecated in TS 6.0 (removed in 7.0).
    // Migrating either surfaces real new errors (Cesium type interop, zod/v4 locale exports-map
    // resolution under Bundler mode) that need dedicated investigation — deferred for now.
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "e2e", "codegen.ts"],
  "exclude": ["src/**/*.stories.tsx"],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
